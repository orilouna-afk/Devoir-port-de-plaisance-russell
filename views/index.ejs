<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <header>
     <h1>Bienvenue au Port de Plaisance Russell</h1>
    </header>
    <p>Le Port de Plaisance Russell, vous propose cette application qui vous permettra de gérer les réservations de catways de vos bateaux via la capitainerie.</p>

    <h2>Connexion capitainerie</h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <p style="color: red;"><%= error %></p>
      <% } %>
      <form method="POST" action="/login">
        <div>
          <label for="email">Email :</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div>
          <label for="password">Mot de passe :</label>
          <input type="password" id="password" name="password" required>
        </div>
        <button type="submit">Se Connecter</button>
      </form>
      <p>
        <a href="/documentation">Accéder à la documentation </a>
      </p>
  </body>
</html>
